# Server
PORT=3009
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clipdeck_dispute
DIRECT_URL=postgresql://user:password@localhost:5432/clipdeck_dispute

# Event Bus
RABBITMQ_URL=amqp://clipdeck:password@localhost:5672
EVENT_EXCHANGE=clipdeck.events

# Auth (JWT verification)
JWT_SECRET=your-jwt-secret-here

# Service Discovery
DISCORD_SERVICE_URL=http://discord-service:3006
CLIP_SERVICE_URL=http://clip-service:3002

# Cors
ALLOWED_ORIGINS=http://localhost:3000
