{
  "name": "@clipdeck/dispute-service",
  "version": "0.1.0",
  "description": "Dispute and support ticket microservice for ClipDeck platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clipdeck/events": "file:../shared-events",
    "@clipdeck/types": "file:../shared-types",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@prisma/client": "^6.1.0",
    "axios": "^1.13.5",
    "fastify": "^5.1.0",
    "pino": "^9.6.0",
    "zod": "^3.24.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^4.1.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "cross-spawn": "^7.0.5",
    "glob": "^10.5.0",
    "minimatch": "^9.0.6",
    "tar": "^7.5.11"
  }
}
